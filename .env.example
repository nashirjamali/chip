# Chip environment variables

# Required for receipt OCR (snap → line items)
OPENROUTER_API_KEY=
# Vision-capable model via OpenRouter (default: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Sepolia RPC (defaults to public endpoint if unset)
SEPOLIA_RPC_URL=https://rpc.sepolia.org
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Circle test USDC on Sepolia (default built-in)
SEPOLIA_USDC_ADDRESS=0x1c7D4B196Cb0C7B29D5D7D6D2c0dD41e7D72cb

# Set to true for local testing without on-chain USDC transfers
# Set to false for production MVP with real Sepolia settlement
CHIP_DEMO_PAYMENTS=true
